# ─── Transport ─────────────────────────────────────────────────────────────────
# MCP transport: "stdio" (default, for Claude Desktop) or "http" (for Docker/K8s)
MCP_TRANSPORT=http

# HTTP port the Node process listens on inside the container
# If using Docker: map host port 443/80 to this container port
MCP_PORT=3000

# ─── Production Settings ───────────────────────────────────────────────────────
NODE_ENV=production

# Log verbosity: debug | info | warn | error
# Use "info" for normal ops, "warn" if you want less noise
LOG_LEVEL=info

# ─── Public URL ────────────────────────────────────────────────────────────────
# Canonical base URL — required for correct OpenAPI server metadata and docs
PUBLIC_BASE_URL=https://mcp.vistaan.com

# ─── Metrics ───────────────────────────────────────────────────────────────────
# Exposes /metrics and /metrics/prometheus
METRICS_ENABLED=true

# ─── Workflows (optional) ──────────────────────────────────────────────────────
# Only uncomment if you mount custom workflow files outside the image
# WORKFLOW_ROOT=/custom/path/to/workflow-files