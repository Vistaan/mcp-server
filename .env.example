# ─── Transport ─────────────────────────────────────────────────────────────────
# MCP transport: "stdio" (default, for Claude Desktop) or "http" (for Docker/K8s)
MCP_TRANSPORT=stdio

# HTTP port — only used when MCP_TRANSPORT=http
MCP_PORT=3000

# ─── Workflows ──────────────────────────────────────────────────────────────────
# Override the bundled workflows/ directory if you want to use external files.
# Default: <project-root>/workflows (bundled, no override needed)
# WORKFLOW_ROOT=/custom/path/to/workflow-files
