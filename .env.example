# Absolute path to the directory containing the seven v4 workflow markdown files.
#
# Expected files:
#   WORKFLOW_OS_v4.md
#   WORKFLOW_FREELANCING_v4.md
#   WORKFLOW_PRODUCTS_v4.md
#   WORKFLOW_CONTENT_v4.md
#   WORKFLOW_EXECUTION_v4.md
#   WORKFLOW_INVESTING_v4.md
#   UTILITY_PROMPTS_v4.md
#   WORKFLOW_EXECUTE_REFERENCING_v4.md
#
# Default: process.cwd() at server startup (NOT recommended for production)
WORKFLOW_ROOT=/absolute/path/to/prompt-engineering/prompting-workflow
